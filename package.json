{
  "name": "distilled-cloudflare",
  "private": true,
  "description": "Monorepo for Effect-native Cloudflare developer tools.",
  "license": "MIT",
  "author": {
    "name": "John Royal",
    "email": "john@alchemy.run",
    "url": "https://distilled.cloud"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alchemy-run/cloudflare-bundler.git"
  },
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "build": "bun run --filter '@distilled.cloud/cloudflare-bundler' build",
    "build:clean": "bun run --filter '@distilled.cloud/cloudflare-bundler' build:clean",
    "format": "oxfmt packages scripts",
    "lint": "oxlint packages scripts",
    "test": "bun run --filter '@distilled.cloud/cloudflare-bundler' test",
    "test:watch": "bun run --filter '@distilled.cloud/cloudflare-bundler' test:watch",
    "typecheck": "bun run scripts/typecheck.ts",
    "submodules": "git submodule update --init --recursive"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "effect-solutions": "^0.5.2",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "typescript": "^6.0.2"
  },
  "packageManager": "bun@1.3.10"
}
