{
  "$schema": "https://raw.githubusercontent.com/Effect-TS/language-service/refs/heads/main/schema.json",
  "extends": "./tsconfig.base.json",
  "include": ["src/**/*"],
  "exclude": ["workers-sdk", "dist"],
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "declaration": true,
    "declarationMap": true,
    "incremental": true,
    "sourceMap": true,
    "plugins": [
      {
        "name": "@effect/language-service"
      }
    ]
  }
}
