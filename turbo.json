{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["bun.lock", "tsconfig.base.json"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".cache/**/*.tsbuildinfo"]
    },
    "format": {
      "cache": false
    },
    "lint": {
      "cache": false
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": [".cache/**/*.tsbuildinfo"]
    },
    "test": {
      "dependsOn": ["build", "^build"],
      "outputs": []
    }
  }
}
